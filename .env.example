# Copy this file to .env.local and fill in real values for local development.
# In production, set these in Vercel → Project → Settings → Environment Variables.

# ── Required ──────────────────────────────────────────────────────────────────
# Windsor.ai API key (from onboard.windsor.ai). Server-side only; never exposed
# to the browser. Powers every live channel fetch.
WINDSOR_API_KEY=

# Secret for the monthly cron route (/api/cron-refresh). Any random string,
# e.g. `openssl rand -hex 16`. Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# ── Optional: auto-bake completed months into lib/baseline.ts ─────────────────
# When set, the monthly cron commits the just-completed month into baseline.ts
# via the GitHub Contents API, so it is served statically and never re-fetched.
# Leave blank to disable auto-baking (the month simply stays live-fetched).
#
# GH_REPO_TOKEN — a GitHub PAT with contents:write on the repo (classic "repo" scope works).
GH_REPO_TOKEN=
# GH_REPO — "owner/name". Defaults to digistex4u/heatronics_dashboard_portfolio.
GH_REPO=digistex4u/heatronics_dashboard_portfolio
# GH_BRANCH — branch to commit to. Defaults to main.
GH_BRANCH=main
